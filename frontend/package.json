{
  "name": "library-desktop-frontend",
  "version": "1.0.0",
  "description": "Desktop app quản lý thư viện",
  "author": "Nhom 1",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env ELECTRON_START_URL=http://localhost:5173 electron .\"",
    "electron:preview": "npm run build && electron .",
    "dist:dir": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "dist:win": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win && node build/cleanup-release.cjs"
  },
  "build": {
    "appId": "com.library.libradesk",
    "productName": "LibraDesk",
    "artifactName": "LibraDesk-${version}-portable.${ext}",
    "directories": {
      "output": "../release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!**/*.map",
      "!**/*.md",
      "!**/README*",
      "!**/CHANGELOG*",
      "!**/LICENSE*"
    ],
    "asar": true,
    "compression": "maximum",
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "afterPack": "build/after-pack.cjs",
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "ia32"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "LibraDesk-Setup-${version}.${ext}",
      "differentialPackage": false,
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LibraDesk",
      "uninstallDisplayName": "LibraDesk"
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@vitejs/plugin-react": "latest",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "lucide-react": "^1.17.0",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "^7.16.0",
    "recharts": "^3.8.1",
    "vite": "latest",
    "wait-on": "^9.0.10"
  }
}

